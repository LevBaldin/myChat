
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User{
  id String @id @default(cuid())
  email String @unique
  name String @unique
  avatar String @default("https://res.cloudinary.com/dk7p9j9ye/image/upload/v1776953782/stock_image_lomcvh.jpg")
  password String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  refreshToken String? @unique
  messages Message[]
  chats Chat[]

}
model Chat{
  id String @id @default(cuid())
  messages Message[]
  participants User[]
}
model Message{
  id String @id @default(cuid())
  content String
  createdAt DateTime @default(now()) 
  chat Chat @relation(fields:[chatId], references: [id])
  chatId String
  sender User @relation(fields: [senderId],references: [id])
  senderId String
}
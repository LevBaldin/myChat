{
    "compilerOptions": {
        "module": "ESNext",
        "ignoreDeprecations": "6.0",
        "moduleResolution": "node",
        "target": "ES2020",
        "strict": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    }
}
